<% const ext = (note.file_original_name || '').split('.').pop().toLowerCase(); %>
<% const googleViewerUrl = 'https://docs.google.com/viewer?url=' + encodeURIComponent(fileUrl) + '&embedded=true'; %>

<!-- TOOLBAR -->
<header class="rd-toolbar">
  <div class="rd-toolbar-left">
    <a href="javascript:history.back()" class="rd-back-btn">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      <span>Back</span>
    </a>
    <div class="rd-sep"></div>
    <span class="rd-ext-pill rd-ext-<%= ext %>"><%= ext.toUpperCase() %></span>
    <div class="rd-note-meta">
      <span class="rd-note-title"><%= note.title %></span>
      <span class="rd-note-sub">
        <%= note.level_name || note.combo_name || '' %>
        <% if (note.class_name) { %> › <%= note.class_name %><% } %>
        · <%= note.file_size_formatted %>
      </span>
    </div>
  </div>
  <div class="rd-toolbar-right">
    <% if (readMode === 'office' || readMode === 'txt') { %>
      <span class="rd-reading-label">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
        </svg>
        Reading online
      </span>
    <% } %>
    <a href="/download/<%= note.id %>" class="rd-download-btn">
      <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
      Download
    </a>
  </div>
</header>

<!-- CONTENT -->
<main class="rd-main">

  <% if (readMode === 'pdf') { %>
    <%# PDF — /view/:id proxies from Cloudinary through our server, stripping X-Frame-Options %>
    <iframe
      src="/view/<%= note.id %>"
      class="rd-pdf-frame"
      title="<%= note.title %>">
    </iframe>

  <% } else if (readMode === 'office') { %>
    <%# DOCX / DOC / PPT / PPTX — Google Docs Viewer fetches the file, no server download needed %>
    <div class="rd-office-wrap">
      <div class="rd-office-loading" id="officeLoading">
        <div class="rd-loading-spinner"></div>
        <p>Loading document viewer…</p>
      </div>
      <iframe
        id="officeFrame"
        src="<%= googleViewerUrl %>"
        class="rd-office-frame"
        title="<%= note.title %>"
        style="display:none"
        onload="document.getElementById('officeLoading').style.display='none'; this.style.display='block';">
      </iframe>
    </div>

  <% } else if (readMode === 'txt') { %>
    <%# TXT — browser fetches directly from Cloudinary via JS %>
    <div class="rd-paper-wrap">
      <div class="rd-paper rd-paper-txt">
        <div id="txtLoading" style="text-align:center;padding:3rem;color:#6b6b80">Loading…</div>
        <pre class="rd-txt-content" id="txtContent" style="display:none"></pre>
      </div>
    </div>
    <script>
      fetch('<%= fileUrl %>')
        .then(r => r.text())
        .then(txt => {
          document.getElementById('txtLoading').style.display = 'none';
          const el = document.getElementById('txtContent');
          el.textContent = txt;
          el.style.display = 'block';
        })
        .catch(err => {
          document.getElementById('txtLoading').textContent = 'Could not load file. Please download it instead.';
        });
    </script>

  <% } else { %>
    <!-- Unsupported format -->
    <div class="rd-unsupported">
      <div class="rd-unsupported-icon">📎</div>
      <h2>Cannot preview this file</h2>
      <p>This file type cannot be previewed online.<br>
         Download it to open with the right app on your device.</p>
      <div class="rd-unsupported-meta">
        <span><strong><%= note.file_original_name %></strong></span>
        <span><%= note.file_size_formatted %></span>
      </div>
      <a href="/download/<%= note.id %>" class="rd-big-download">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download File
      </a>
    </div>
  <% } %>

</main>
