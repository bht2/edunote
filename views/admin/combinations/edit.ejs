<div class="admin-page">
  <div class="admin-page-header">
    <h1>Edit <%= combo.name %></h1>
    <a href="/admin/levels/<%= level.id %>/combinations" class="btn btn-secondary">← Back</a>
  </div>
  <div class="form-card">
    <form action="/admin/levels/<%= level.id %>/combinations/<%= combo.id %>" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label>Short Name *</label>
          <input type="text" name="name" value="<%= combo.name %>" required>
        </div>
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="full_name" value="<%= combo.full_name %>">
        </div>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" rows="2"><%= combo.description %></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Color</label>
          <input type="color" name="color" value="<%= combo.color %>">
        </div>
        <div class="form-group">
          <label>Order</label>
          <input type="number" name="order_index" value="<%= combo.order_index %>" min="0">
        </div>
      </div>
      <button type="submit" class="btn btn-primary">Update</button>
    </form>
  </div>
</div>
