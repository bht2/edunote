<div class="admin-page">
  <div class="admin-page-header">
    <h1>Settings</h1>
  </div>

  <div class="settings-grid">
    <!-- Avatar -->
    <div class="settings-card">
      <h3>Profile Photo</h3>
      <div class="avatar-section">
        <% if (admin.avatar) { %>
          <img src="<%= admin.avatar %>" alt="Avatar" class="settings-avatar">
        <% } else { %>
          <div class="settings-avatar-placeholder"><%= admin.name[0].toUpperCase() %></div>
        <% } %>
        <div class="avatar-actions">
          <form action="/admin/settings/avatar" method="POST" enctype="multipart/form-data">
            <input type="file" name="avatar" id="avatarInput" accept="image/*" style="display:none" onchange="this.form.submit()">
            <label for="avatarInput" class="btn btn-secondary">Change Photo</label>
          </form>
          <% if (admin.avatar) { %>
          <form action="/admin/settings/avatar/remove" method="POST">
            <button type="submit" class="btn btn-danger-outline">Remove</button>
          </form>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Profile -->
    <div class="settings-card">
      <h3>Profile</h3>
      <form action="/admin/settings/profile" method="POST">
        <div class="form-group">
          <label>Name</label>
          <input type="text" name="name" value="<%= admin.name %>" required>
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" value="<%= admin.email %>" required>
        </div>
        <button type="submit" class="btn btn-primary">Update Profile</button>
      </form>
    </div>

    <!-- Password -->
    <div class="settings-card">
      <h3>Change Password</h3>
      <form action="/admin/settings/password" method="POST">
        <div class="form-group">
          <label>Current Password</label>
          <input type="password" name="current_password" required>
        </div>
        <div class="form-group">
          <label>New Password</label>
          <input type="password" name="new_password" required minlength="6">
        </div>
        <div class="form-group">
          <label>Confirm New Password</label>
          <input type="password" name="confirm_password" required>
        </div>
        <button type="submit" class="btn btn-primary">Update Password</button>
      </form>
    </div>
  </div>
</div>
