<div class="admin-page">
  <div class="admin-page-header">
    <div>
      <h1>👥 Sub-Admins</h1>
      <p>Each sub-admin manages one education level. All combination changes require your approval.</p>
    </div>
    <a href="/admin/subadmins/create" class="btn btn-primary">+ Add Sub-Admin</a>
  </div>

  <% if (admins.length === 0) { %>
    <div class="admin-table-card">
      <div class="empty-state">
        <p>No sub-admins yet. <a href="/admin/subadmins/create">Add the first one</a></p>
      </div>
    </div>
  <% } else { %>
    <div class="admin-table-card">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Admin</th>
            <th>Email</th>
            <th>Assigned Level</th>
            <th>Permissions</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% admins.forEach(a => { %>
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:.6rem">
                <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--accent),#818cf8);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.875rem;flex-shrink:0">
                  <%= a.name.charAt(0).toUpperCase() %>
                </div>
                <strong><%= a.name %></strong>
              </div>
            </td>
            <td style="color:var(--muted);font-size:.875rem"><%= a.email %></td>
            <td>
              <% if (a.level_name) { %>
                <span style="background:var(--accent-light);color:var(--accent);padding:.25rem .75rem;border-radius:100px;font-size:.78rem;font-weight:700"><%= a.level_name %></span>
              <% } else { %>
                <span style="color:var(--muted-lt);font-size:.85rem">None assigned</span>
              <% } %>
            </td>
            <td style="font-size:.8rem;color:var(--muted)">
              <div>✅ Add/edit classes &amp; notes</div>
              <div>⏳ Combo changes → need approval</div>
            </td>
            <td style="color:var(--muted-lt);font-size:.82rem">
              <%= new Date(a.created_at).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}) %>
            </td>
            <td class="table-actions">
              <a href="/admin/subadmins/<%= a.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
              <form action="/admin/subadmins/<%= a.id %>/delete" method="POST" style="display:inline"
                    onsubmit="return confirm('Delete <%= a.name %>?')">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
