<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <div class="mobile-topbar" id="mobileTopbar">
    <a href="/admin/dashboard" class="mobile-logo">✦ Edu<strong>Note</strong></a>
    <button class="mobile-sidebar-btn" id="sidebarToggleBtn" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <div class="admin-layout">
    <aside class="sidebar" id="adminSidebar">
      <div class="sidebar-header">
        <a href="/admin/dashboard" class="sidebar-logo">✦ Edu<strong>Note</strong></a>
        <button class="sidebar-close-btn" id="sidebarCloseBtn" aria-label="Close">✕</button>
      </div>

      <div class="sidebar-admin">
        <% if (locals.adminAvatar && adminAvatar) { %>
          <img src="<%= adminAvatar %>" alt="Avatar" class="admin-avatar">
        <% } else { %>
          <div class="admin-avatar-placeholder"><%= (locals.adminName || 'A')[0].toUpperCase() %></div>
        <% } %>
        <div class="admin-info">
          <span class="admin-name"><%= locals.adminName || 'Admin' %></span>
          <span class="admin-role"><%= locals.adminRole === 'admin' ? 'Main Admin' : 'Sub-Admin' %></span>
        </div>
      </div>

      <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="nav-item <%= locals.title && title.includes('Dashboard') ? 'active' : '' %>">
          <span class="nav-icon">🏠</span> Dashboard
        </a>

        <% if (locals.isSuperAdmin) { %>
          <!-- MAIN ADMIN NAVIGATION -->
          <div class="nav-section">Academic Structure</div>
          <a href="/admin/levels" class="nav-item <%= locals.title && (title.includes('Level') || title.includes('Combination') || title.includes('Class') || title.includes('Notes')) ? 'active' : '' %>">
            <span class="nav-icon">🎓</span> Education Levels
          </a>

          <div class="nav-section">Team</div>
          <a href="/admin/subadmins" class="nav-item <%= locals.title && title.includes('Sub-Admin') ? 'active' : '' %>">
            <span class="nav-icon">👥</span> Sub-Admins
          </a>
          <a href="/admin/requests" class="nav-item <%= locals.title && title.includes('Request') ? 'active' : '' %>">
            <span class="nav-icon">📋</span> Requests
          </a>

        <% } else { %>
          <!-- SUB-ADMIN NAVIGATION — only their assigned level -->
          <div class="nav-section">My Level</div>
          <% if (locals.adminLevelId) { %>
            <a href="/admin/levels/<%= locals.adminLevelId %>/combinations" class="nav-item <%= locals.title && (title.includes('Combination') || title.includes('Class') || title.includes('Notes')) ? 'active' : '' %>">
              <span class="nav-icon">📚</span> Combinations
            </a>
          <% } %>

          <div class="nav-section">Requests</div>
          <a href="/admin/dashboard#my-requests" class="nav-item">
            <span class="nav-icon">📋</span> My Requests
          </a>
        <% } %>

        <div class="nav-section">Account</div>
        <% if (locals.isSuperAdmin) { %>
          <a href="/" target="_blank" class="nav-item"><span class="nav-icon">🌐</span> View Site</a>
        <% } %>
        <a href="/admin/settings" class="nav-item <%= locals.title && title.includes('Settings') ? 'active' : '' %>">
          <span class="nav-icon">⚙️</span> Settings
        </a>
        <a href="/admin/logout" class="nav-item nav-logout">
          <span class="nav-icon">🚪</span> Logout
        </a>
      </nav>
    </aside>

    <div class="admin-main">
      <% if (locals.success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success"><%= success_msg %></div>
      <% } %>
      <% if (locals.error_msg && error_msg.length > 0) { %>
        <div class="alert alert-error"><%= error_msg %></div>
      <% } %>
      <%- body %>
    </div>
  </div>

  <script src="/js/admin.js"></script>
</body>
</html>
