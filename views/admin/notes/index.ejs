<div class="admin-page">
  <div class="admin-page-header">
    <div>
      <div class="breadcrumb-admin">
        <a href="/admin/combinations/<%= combo.id %>/classes"><%= combo.name %></a> › <%= cls.name %> › Notes
      </div>
      <h1><span class="combo-badge" style="background:<%= combo.color %>"><%= combo.name %></span> <%= cls.name %> — Notes</h1>
    </div>
    <a href="/admin/classes/<%= cls.id %>/notes/create" class="btn btn-primary">+ Upload Note</a>
  </div>

  <div class="admin-table-card">
    <% if (notes.length === 0) { %>
      <div class="empty-state">
        <p>No notes uploaded yet. <a href="/admin/classes/<%= cls.id %>/notes/create">Upload the first note</a></p>
      </div>
    <% } else { %>
      <table class="admin-table">
        <thead><tr><th>Title</th><th>Subject</th><th>Size</th><th>Downloads</th><th>Actions</th></tr></thead>
        <tbody>
          <% notes.forEach(note => { %>
          <tr>
            <td><strong><%= note.title %></strong></td>
            <td><%= note.subject || '—' %></td>
            <td><%= note.file_size_formatted %></td>
            <td><%= note.download_count %></td>
            <td class="table-actions">
              <a href="/read/<%= note.id %>" target="_blank" class="btn btn-sm btn-secondary">View</a>
              <a href="/admin/classes/<%= cls.id %>/notes/<%= note.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
              <form action="/admin/classes/<%= cls.id %>/notes/<%= note.id %>/delete" method="POST" style="display:inline" onsubmit="return confirm('Delete this note?')">
                <button class="btn btn-sm btn-danger">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>
