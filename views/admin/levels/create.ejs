<div class="admin-page">
  <div class="admin-page-header">
    <h1>Add Education Level</h1>
    <a href="/admin/levels" class="btn btn-secondary">← Back</a>
  </div>
  <div class="form-card">
    <form action="/admin/levels" method="POST">
      <div class="form-group">
        <label>Level Name *</label>
        <input type="text" name="name" placeholder="e.g. O'Level" required>
      </div>
      <div class="form-group">
        <label>Description</label>
        <input type="text" name="description" placeholder="Short description">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Color</label>
          <input type="color" name="color" value="#4f46e5">
        </div>
        <div class="form-group">
          <label>Icon (emoji)</label>
          <input type="text" name="icon" value="📚" maxlength="5">
        </div>
        <div class="form-group">
          <label>Order</label>
          <input type="number" name="order_index" value="0" min="0">
        </div>
      </div>
      <button type="submit" class="btn btn-primary">Create Level</button>
    </form>
  </div>
</div>
