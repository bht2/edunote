<div class="admin-page">
  <div class="admin-page-header">
    <h1>Edit Level</h1>
    <a href="/admin/levels" class="btn btn-secondary">← Back</a>
  </div>
  <div class="form-card">
    <form action="/admin/levels/<%= level.id %>" method="POST">
      <div class="form-group">
        <label>Level Name *</label>
        <input type="text" name="name" value="<%= level.name %>" required>
      </div>
      <div class="form-group">
        <label>Description</label>
        <input type="text" name="description" value="<%= level.description %>">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Color</label>
          <input type="color" name="color" value="<%= level.color %>">
        </div>
        <div class="form-group">
          <label>Icon (emoji)</label>
          <input type="text" name="icon" value="<%= level.icon %>" maxlength="5">
        </div>
        <div class="form-group">
          <label>Order</label>
          <input type="number" name="order_index" value="<%= level.order_index %>" min="0">
        </div>
      </div>
      <button type="submit" class="btn btn-primary">Update Level</button>
    </form>
  </div>
</div>
