<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/public.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <span class="logo-icon">\u2726</span>
        <span>Edu<strong>Note</strong></span>
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/notes">Browse Notes</a></li>
      </ul>
      <div class="nav-cta">
        <a href="/notes" class="btn btn-primary">Get Notes</a>
      </div>
      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <div class="mobile-menu" id="mobileMenu">
    <a href="/">Home</a>
    <a href="/notes">Browse Notes</a>
    <a href="/notes" class="btn btn-primary">Get Notes</a>
  </div>

  <% if (success && success.length > 0) { %>
    <div class="flash flash-success"><%= success %></div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="flash flash-error"><%= error %></div>
  <% } %>

  <%- body %>

  <footer class="footer">
    <div class="footer-container">
      <div class="footer-brand">
        <a href="/" class="nav-logo"><span class="logo-icon">\u2726</span><span>Edu<strong>Note</strong></span></a>
        <p>Quality educational resources, freely accessible to every student.</p>
      </div>
      <div class="footer-links">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/notes">Browse Notes</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> EduNote. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/public.js"></script>
</body>
</html>