<div class="admin-page">
  <div class="admin-page-header">
    <div>
      <div class="breadcrumb-admin"><a href="/admin/subadmins">Sub-Admins</a> › Add New</div>
      <h1>Add Sub-Admin</h1>
      <p>Assign an admin to a specific education level</p>
    </div>
    <a href="/admin/subadmins" class="btn btn-secondary">← Back</a>
  </div>

  <div class="form-card">
    <form action="/admin/subadmins" method="POST">
      <div class="form-group">
        <label>Full Name <span class="required">*</span></label>
        <input type="text" name="name" placeholder="e.g. John Doe" required>
      </div>
      <div class="form-group">
        <label>Email Address <span class="required">*</span></label>
        <input type="email" name="email" placeholder="admin@example.com" required>
      </div>
      <div class="form-group">
        <label>Password <span class="required">*</span></label>
        <input type="password" name="password" placeholder="Min 6 characters" minlength="6" required>
      </div>
      <div class="form-group">
        <label>Assigned Level <span class="required">*</span></label>
        <select name="level_id" required>
          <option value="">— Select a level —</option>
          <% levels.forEach(l => { %>
            <option value="<%= l.id %>"><%= l.icon %> <%= l.name %></option>
          <% }) %>
        </select>
        <p class="form-hint">This admin will only manage content under this level.</p>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Create Sub-Admin</button>
        <a href="/admin/subadmins" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
