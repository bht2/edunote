<div class="admin-page">
  <div class="admin-page-header">
    <div>
      <div class="breadcrumb-admin"><a href="/admin/combinations/<%= combo.id %>/classes"><%= combo.name %></a> › Add Class</div>
      <h1>Add Class to <%= combo.name %></h1>
    </div>
    <a href="/admin/combinations/<%= combo.id %>/classes" class="btn btn-secondary">← Back</a>
  </div>
  <div class="form-card">
    <form action="/admin/combinations/<%= combo.id %>/classes" method="POST">
      <div class="form-group">
        <label>Class Name * (e.g. S4, S5, S6, L3, L4, L5)</label>
        <input type="text" name="name" placeholder="S4" required>
      </div>
      <div class="form-group">
        <label>Order</label>
        <input type="number" name="order_index" value="0" min="0">
      </div>
      <button type="submit" class="btn btn-primary">Create Class</button>
    </form>
  </div>
</div>
