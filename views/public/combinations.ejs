<!-- Page Header -->
<section class="page-header" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep">›</span>
      <a href="/browse">Levels</a>
      <span class="bc-sep">›</span>
      <span><%= level.name %></span>
    </nav>
    <div class="sector-header-info" style="margin-top:1.25rem">
      <div class="sector-icon-lg" style="background:<%= level.color %>22;border:1px solid <%= level.color %>40">
        <span style="color:<%= level.color %>"><%= level.icon || level.name.charAt(0) %></span>
      </div>
      <div>
        <h1 style="color:white;font-size:1.875rem"><%= level.name %></h1>
        <% if (level.description) { %>
          <p style="color:rgba(255,255,255,0.55);font-size:0.9rem;margin-top:0.4rem"><%= level.description %></p>
        <% } %>
      </div>
    </div>
  </div>
</section>

<section class="level-picker-section">
  <div class="container">
    <div class="level-picker-header">
      <h2><% if (level.slug === 'tvet') { %>Select Your Trade<% } else { %>Select Your Combination<% } %></h2>
      <p>Choose <% if (level.slug === 'tvet') { %>your trade<% } else { %>your combination<% } %> to browse available classes and notes</p>
    </div>

    <% if (combinations.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">📭</div>
        <h3>No combinations yet</h3>
        <p>Notes will be available soon for <strong><%= level.name %></strong>.</p>
        <a href="/" class="btn btn-outline-dark" style="margin-top:1.5rem">← Back to Home</a>
      </div>

    <% } else if (level.slug === 'tvet') { %>
      <!-- TVET: Cards grid (like homepage level cards) -->
      <div class="sectors-grid">
        <% combinations.forEach(combo => { %>
          <a href="/browse/<%= level.slug %>/<%= combo.slug %>" class="sector-card" style="--sector-color: <%= combo.color %>">
            <div class="sector-card-top">
              <div class="sector-icon-wrap">
                <span class="sector-symbol"><%= combo.name.substring(0, 3) %></span>
              </div>
              <span class="sector-count"><%= combo.class_count || 0 %> classes</span>
            </div>
            <h3 class="sector-name"><%= combo.name %></h3>
            <p class="sector-desc"><%= combo.full_name || combo.description || 'Browse notes for this trade.' %></p>
            <div class="sector-cta">
              View Classes
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </a>
        <% }) %>
      </div>

    <% } else { %>
      <!-- O'Level / A'Level: List-style picker cards -->
      <div class="level-picker-grid">
        <% combinations.forEach((combo, i) => { %>
          <a href="/browse/<%= level.slug %>/<%= combo.slug %>" class="level-picker-card" style="--lc: <%= combo.color %>">
            <div class="lpc-left">
              <div class="lpc-num" style="background:<%= combo.color %>"><%= combo.name %></div>
              <div class="lpc-info">
                <h3><%= combo.full_name || combo.name %></h3>
                <% if (combo.description) { %><p><%= combo.description %></p><% } %>
              </div>
            </div>
            <div class="lpc-right">
              <span class="lpc-count"><%= combo.class_count || 0 %> classes</span>
              <span class="lpc-arrow">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </div>
          </a>
        <% }) %>
      </div>

    <% } %>
  </div>
</section>
