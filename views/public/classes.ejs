<!-- Page Header -->
<section class="page-header" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span class="bc-sep">›</span>
      <a href="/browse">Levels</a>
      <span class="bc-sep">›</span>
      <a href="/browse/<%= level.slug %>"><%= level.name %></a>
      <span class="bc-sep">›</span>
      <span><%= combo.name %></span>
    </nav>
    <div class="sector-header-info" style="margin-top:1.25rem">
      <div class="sector-icon-lg" style="background:<%= combo.color %>22;border:1px solid <%= combo.color %>40">
        <span style="color:<%= combo.color %>"><%= combo.name.charAt(0) %></span>
      </div>
      <div>
        <h1 style="color:white;font-size:1.875rem"><%= combo.full_name || combo.name %></h1>
        <p style="color:rgba(255,255,255,0.55);font-size:0.9rem;margin-top:0.4rem">
          <span style="background:<%= level.color %>25;color:white;padding:0.2rem 0.75rem;border-radius:100px;font-size:0.8rem;font-weight:600;border:1px solid <%= level.color %>40">◑ <%= level.name %></span>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Classes -->
<section class="level-picker-section">
  <div class="container">
    <div class="level-picker-header">
      <h2>Select Your Class</h2>
      <p>Choose a class to view available notes</p>
    </div>

    <% if (classes.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">📭</div>
        <h3>No classes yet</h3>
        <p>Notes will be available soon for <strong><%= combo.name %></strong>.</p>
        <a href="/browse/<%= level.slug %>" class="btn btn-outline-dark" style="margin-top:1.5rem">← Back to combinations</a>
      </div>
    <% } else { %>
      <div class="level-picker-grid" style="max-width:600px">
        <% classes.forEach((cls, i) => { %>
          <a href="/browse/<%= level.slug %>/<%= combo.slug %>/<%= cls.slug %>" class="level-picker-card" style="--lc: <%= combo.color %>">
            <div class="lpc-left">
              <div class="lpc-num" style="background:<%= combo.color %>;font-size:1rem"><%= cls.name %></div>
              <div class="lpc-info">
                <h3><%= cls.name %></h3>
                <p><%= combo.name %> · <%= level.name %></p>
              </div>
            </div>
            <div class="lpc-right">
              <span class="lpc-count"><%= cls.note_count || 0 %> notes</span>
              <span class="lpc-arrow">
                <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
