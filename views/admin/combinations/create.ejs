<div class="admin-page">
  <div class="admin-page-header">
    <div>
      <div class="breadcrumb-admin"><a href="/admin/levels">Levels</a> › <a href="/admin/levels/<%= level.id %>/combinations"><%= level.name %></a> › Add</div>
      <h1>Add <% if(level.slug==='tvet'){ %>Trade<% }else{ %>Combination<% } %></h1>
    </div>
    <a href="/admin/levels/<%= level.id %>/combinations" class="btn btn-secondary">← Back</a>
  </div>
  <div class="form-card">
    <form action="/admin/levels/<%= level.id %>/combinations" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label>Short Name * (e.g. MPC, SOD)</label>
          <input type="text" name="name" placeholder="MPC" required>
        </div>
        <div class="form-group">
          <label>Full Name</label>
          <input type="text" name="full_name" placeholder="Mathematics, Physics, Chemistry">
        </div>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" rows="2" placeholder="Optional description"></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Color</label>
          <input type="color" name="color" value="#6366f1">
        </div>
        <div class="form-group">
          <label>Order</label>
          <input type="number" name="order_index" value="0" min="0">
        </div>
      </div>
      <button type="submit" class="btn btn-primary">Create</button>
    </form>
  </div>
</div>
