<div class="admin-page">
  <div class="admin-page-header">
    <h1>Edit Class <%= cls.name %></h1>
    <a href="/admin/combinations/<%= combo.id %>/classes" class="btn btn-secondary">← Back</a>
  </div>
  <div class="form-card">
    <form action="/admin/combinations/<%= combo.id %>/classes/<%= cls.id %>" method="POST">
      <div class="form-group">
        <label>Class Name *</label>
        <input type="text" name="name" value="<%= cls.name %>" required>
      </div>
      <div class="form-group">
        <label>Order</label>
        <input type="number" name="order_index" value="<%= cls.order_index %>" min="0">
      </div>
      <button type="submit" class="btn btn-primary">Update Class</button>
    </form>
  </div>
</div>
