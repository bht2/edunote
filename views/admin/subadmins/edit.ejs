<div class="admin-page">
  <div class="admin-page-header">
    <div>
      <div class="breadcrumb-admin"><a href="/admin/subadmins">Sub-Admins</a> › Edit</div>
      <h1>Edit Sub-Admin</h1>
      <p>Update details for <%= subAdmin.name %></p>
    </div>
    <a href="/admin/subadmins" class="btn btn-secondary">← Back</a>
  </div>

  <div class="form-card">
    <form action="/admin/subadmins/<%= subAdmin.id %>" method="POST">
      <div class="form-group">
        <label>Full Name <span class="required">*</span></label>
        <input type="text" name="name" value="<%= subAdmin.name %>" required>
      </div>
      <div class="form-group">
        <label>Email Address <span class="required">*</span></label>
        <input type="email" name="email" value="<%= subAdmin.email %>" required>
      </div>
      <div class="form-group">
        <label>Assigned Level <span class="required">*</span></label>
        <select name="level_id" required>
          <option value="">— Select a level —</option>
          <% levels.forEach(l => { %>
            <option value="<%= l.id %>" <%= subAdmin.level_id == l.id ? 'selected' : '' %>>
              <%= l.icon %> <%= l.name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>New Password <span class="form-hint-inline">(leave blank to keep current)</span></label>
        <input type="password" name="new_password" placeholder="Enter new password to change it" minlength="6">
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/admin/subadmins" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
